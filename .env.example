# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Telegram Bot Token for notification services
TELEGRAM_BOT_TOKEN=

# Courier API Configuration (Free alternative to Twilio for multi-channel notifications)
# Signup at courier.com to get your API key.
COURIER_AUTH_TOKEN=

# SMTP Configuration for Email services
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
