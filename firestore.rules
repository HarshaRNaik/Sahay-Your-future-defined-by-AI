rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Hardened Global Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 200 &&
               data.skills is list && data.skills.size() <= 20 &&
               (data.skills.size() == 0 || data.skills[0] is string) &&
               data.uid == request.auth.uid;
      }

      allow get: if isSignedIn();
      allow list: if false; // Users can't list other users
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt && incoming().uid == existing().uid;
    }

    // 2. Jobs (Publicly readable, created by employers)
    match /jobs/{jobId} {
      function isValidJob(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.company is string && data.company.size() <= 200 &&
               data.location is string && data.location.size() <= 200;
      }

      allow read: if true; // Public listings
      // Created by backend or employers in future
      allow create: if isSignedIn() && isValidId(jobId) && isValidJob(incoming());
      allow update: if false; // System immutable for now
      allow delete: if false;
    }

    // 3. Applications
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.workerId is string && data.workerId == request.auth.uid &&
               data.jobId is string && data.jobId.size() <= 128 &&
               data.status in ['applied', 'vetting', 'hired', 'rejected'];
      }

      allow get: if isSignedIn() && (isOwner(existing().workerId) || exists(/databases/$(database)/documents/jobs/$(existing().jobId)));
      allow list: if isSignedIn() && (resource.data.workerId == request.auth.uid);
      allow create: if isSignedIn() && isEmailVerified() && isValidId(applicationId) && isValidApplication(incoming()) &&
                      incoming().createdAt == request.time &&
                      exists(/databases/$(database)/documents/jobs/$(incoming().jobId));
      allow update: if false; // Status updates handled via backend/contractor node
    }
  }
}
